{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "buildCommand": "npm run build",
  "routes": [
    { "src": "^/$", "dest": "/" },

    { "src": "^/login$", "dest": "/login" },
    { "src": "^/video$", "dest": "/video" },
    { "src": "^/perfil$", "dest": "/perfil" },
    { "src": "^/analytics$", "dest": "/analytics" },
    { "src": "^/face$", "dest": "/face" },

    { "src": "^/admin/dashboard$", "dest": "/admin/dashboard" },
    { "src": "^/admin/videos$", "dest": "/admin/videos" },
    { "src": "^/admin/categorias$", "dest": "/admin/categorias" },
    { "src": "^/admin/comentarios$", "dest": "/admin/comentarios" },
    { "src": "^/admin/analytics$", "dest": "/admin/analytics" },

    { "src": "^/admin-setter$", "dest": "/admin-setter" },
    { "src": "^/setup-admin$", "dest": "/setup-admin" },

    { "src": "^/api/(.*)$", "dest": "/api/$1" }
  ]
}
